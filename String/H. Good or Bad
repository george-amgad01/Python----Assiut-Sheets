        if i == len(n) - 2:
            print("Bad")
            break
        else :
            if n[i] == "0" and n[i+1] == "1" and n[i+2] == "0" :
                print("Good")
                break
            elif n[i] == "1" and n[i+1] == "0" and n[i+2] == "1" :
                print("Good")
                break
